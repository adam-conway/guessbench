      "name": "prompt_hash",
      "header_text": "\n\ndef prompt_hash(artifact_text: str) -> str:\n",
      "span": {
        "start_line": 19,
        "end_line": 22
      },
      "body": [
        {
          "type": "statement",
          "id": "st-0012",
          "text": "    return hashlib.sha256(artifact_text.encode(\"utf-8\")).hexdigest()[:16]\n",
          "kind": "return",
