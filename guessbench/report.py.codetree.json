      }
    },
    {
      "type": "scope",
      "id": "sc-0002",
      "kind": "function",
      "name": "_snippet",
      "header_text": "\n\ndef _snippet(text: str, limit: int = 160) -> str:\n",
      "span": {
        "start_line": 23,
        "end_line": 27
      },
      "body": [
        {
          "type": "statement",
          "id": "st-0013",
          "text": "    flat = \" \".join(text.strip().split())\n",
          "kind": "assign",
          "span": {
            "start_line": 26,
            "end_line": 26
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0014",
          "text": "    return flat[:limit] + (\"…\" if len(flat) > limit else \"\")\n",
          "kind": "return",
          "span": {
            "start_line": 27,
            "end_line": 27
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        }
      ],
      "authored_by": "Adam Conway",
      "authored_at": "2026-07-02T02:43:03Z",
      "author_type": "human",
      "authorship_context": {
