        "commit_summary": "Initial commit"
      }
    },
    {
      "type": "scope",
      "id": "sc-0003",
      "kind": "function",
      "name": "build_report",
      "header_text": "\n\ndef build_report(\n    artifact_text: str,\n    sample_set: SampleSet,\n    clustering: ClusteringResult,\n    config: RunConfig,\n    cache: Cache,\n    strategy_version: str,\n) -> dict:\n",
      "span": {
        "start_line": 28,
        "end_line": 80
      },
      "body": [
        {
          "type": "statement",
          "id": "st-0015",
          "text": "    score = score_assignments(\n        clustering.assignments,\n        bootstrap_iterations=config.bootstrap_iterations,\n        seed=config.seed,\n    )\n",
          "kind": "assign",
          "span": {
            "start_line": 38,
            "end_line": 42
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0016",
          "text": "\n    cluster_table = []\n",
          "kind": "assign",
          "span": {
            "start_line": 43,
            "end_line": 44
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0017",
          "text": "    members_by_cluster: dict[int, list[int]] = {}\n",
          "kind": "assign",
          "span": {
            "start_line": 45,
            "end_line": 45
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0018",
          "text": "    for sample_idx, cluster_id in enumerate(clustering.assignments):\n        members_by_cluster.setdefault(cluster_id, []).append(sample_idx)\n",
          "kind": "for",
          "span": {
            "start_line": 46,
            "end_line": 47
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0019",
          "text": "    for cluster_id, members in sorted(\n        members_by_cluster.items(), key=lambda item: -len(item[1])\n    ):\n        cluster_table.append(\n            {\n                \"cluster_id\": cluster_id,\n                \"size\": len(members),\n                \"fraction\": len(members) / score.n,\n                \"exemplar\": _snippet(sample_set.samples[members[0]]),\n                \"member_indices\": members,\n            }\n        )\n",
          "kind": "for",
          "span": {
            "start_line": 48,
            "end_line": 59
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0020",
          "text": "\n    return {\n        \"stamp\": (\n            f\"EI@{{model={config.reference_model}, T={config.temperature}, \"\n            f\"N={config.n_samples}, strategy={config.strategy}:{strategy_version}}}\"\n        ),\n        \"ei\": round(score.ei, 3),\n        \"ei_ci_90\": [round(score.ei_ci_low, 3), round(score.ei_ci_high, 3)],\n        \"entropy_nats\": round(score.entropy, 4),\n        \"k\": score.k,\n        \"n\": score.n,\n        \"config\": config.to_record(),\n        \"prompt_hash\": prompt_hash(artifact_text),\n        \"strategy_version\": strategy_version,\n        \"cluster_table\": cluster_table,\n        \"difference_labels\": dict(Counter(clustering.difference_labels)),\n        \"non_transitivity_log\": clustering.non_transitivity_log,\n        \"refusal_fraction\": round(sample_set.refusal_fraction, 3),\n        \"low_confidence\": sample_set.low_confidence,\n        \"cache_stats\": cache.stats(),\n    }\n",
          "kind": "return",
          "span": {
            "start_line": 60,
            "end_line": 80
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        }
      ],
      "authored_by": "Adam Conway",
      "authored_at": "2026-07-02T02:43:03Z",
      "author_type": "human",
      "authorship_context": {
        "commit": "97836b7825606e28d73cd124115b163278273a35",
        "commit_summary": "Initial commit"
      }
    },
    {
      "type": "scope",
      "id": "sc-0004",
      "kind": "function",
      "name": "render_report",
      "header_text": "\n\ndef render_report(report: dict) -> str:\n",
      "span": {
        "start_line": 81,
        "end_line": 113
      },
      "body": [
        {
          "type": "statement",
          "id": "st-0021",
          "text": "    \"\"\"Human-readable rendering of a report dict.\"\"\"\n",
          "kind": "docstring",
          "span": {
            "start_line": 84,
            "end_line": 84
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0022",
          "text": "    lines = [\n        report[\"stamp\"],\n        \"\",\n        f\"  EI = {report['ei']}   90% CI [{report['ei_ci_90'][0]}, {report['ei_ci_90'][1]}]\",\n        f\"  H  = {report['entropy_nats']} nats   k = {report['k']} clusters   N = {report['n']} samples\",\n        f\"  prompt_hash = {report['prompt_hash']}   config_hash = {report['config']['config_hash']}\",\n        f\"  refusal fraction = {report['refusal_fraction']:.0%}\"\n        + (\"   ** LOW_CONFIDENCE (refusals > 20%) **\" if report[\"low_confidence\"] else \"\"),\n        \"\",\n        \"  Clusters:\",\n    ]\n",
          "kind": "assign",
          "span": {
            "start_line": 85,
            "end_line": 95
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0023",
          "text": "    for row in report[\"cluster_table\"]:\n        lines.append(\n            f\"    [{row['size']:>2}/{report['n']}] ({row['fraction']:.0%})  {row['exemplar']}\"\n        )\n",
          "kind": "for",
          "span": {
            "start_line": 96,
            "end_line": 99
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0024",
          "text": "    if report[\"difference_labels\"]:\n        lines.append(\"\")\n        lines.append(\"  Difference dimensions (from DIFFERENT verdicts):\")\n        for label, count in sorted(report[\"difference_labels\"].items(), key=lambda kv: -kv[1]):\n            lines.append(f\"    {count}x {label}\")\n",
          "kind": "if",
          "span": {
            "start_line": 100,
            "end_line": 104
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0025",
          "text": "    if report[\"non_transitivity_log\"]:\n        lines.append(\"\")\n        lines.append(\n            f\"  Non-transitive judgment triples observed: {len(report['non_transitivity_log'])}\"\n        )\n",
          "kind": "if",
          "span": {
            "start_line": 105,
            "end_line": 109
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0026",
          "text": "    stats = report[\"cache_stats\"]\n",
          "kind": "assign",
          "span": {
            "start_line": 110,
            "end_line": 110
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0027",
          "text": "    lines.append(\"\")\n",
          "kind": "expr",
          "span": {
            "start_line": 111,
            "end_line": 111
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0028",
          "text": "    lines.append(f\"  Cache: {stats['hits']} hits / {stats['misses']} misses\")\n",
          "kind": "expr",
          "span": {
            "start_line": 112,
            "end_line": 112
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0029",
          "text": "    return \"\\n\".join(lines)\n",
          "kind": "return",
          "span": {
            "start_line": 113,
            "end_line": 113
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        }
      ],
      "authored_by": "Adam Conway",
      "authored_at": "2026-07-02T02:43:03Z",
      "author_type": "human",
      "authorship_context": {
        "commit": "97836b7825606e28d73cd124115b163278273a35",
        "commit_summary": "Initial commit"
      }
    },
    {
      "type": "scope",
      "id": "sc-0005",
      "kind": "function",
      "name": "score_artifact",
      "header_text": "\n\ndef score_artifact(artifact_text: str, config: RunConfig, client: ModelClient, cache: Cache) -> dict:\n",
      "span": {
        "start_line": 114,
        "end_line": 121
      },
      "body": [
        {
          "type": "statement",
          "id": "st-0030",
          "text": "    \"\"\"Full pipeline for one artifact: sample -> cluster -> score -> report.\"\"\"\n",
          "kind": "docstring",
          "span": {
            "start_line": 117,
            "end_line": 117
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0031",
          "text": "    sample_set = draw_samples(artifact_text, config, client, cache)\n",
          "kind": "assign",
          "span": {
            "start_line": 118,
            "end_line": 118
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0032",
          "text": "    strategy = make_strategy(config.strategy)\n",
          "kind": "assign",
          "span": {
            "start_line": 119,
            "end_line": 119
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
