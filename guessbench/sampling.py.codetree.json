    {
      "type": "scope",
      "id": "sc-0005",
      "kind": "function",
      "name": "draw_samples",
      "header_text": "\n\ndef draw_samples(artifact_text: str, config: RunConfig, client: ModelClient, cache: Cache) -> SampleSet:\n",
      "span": {
        "start_line": 53,
        "end_line": 93
      },
      "body": [
        {
          "type": "statement",
          "id": "st-0020",
          "text": "    \"\"\"Draw config.n_samples independent completions (SPEC 2.1), content-addressed\n    cached per (model, T, max_tokens, artifact, sample_index).\"\"\"\n",
          "kind": "docstring",
          "span": {
            "start_line": 56,
            "end_line": 57
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0021",
          "text": "    samples: list[str] = []\n",
          "kind": "assign",
          "span": {
            "start_line": 58,
            "end_line": 58
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0022",
          "text": "    for i in range(config.n_samples):\n        # The run seed offsets the sample index so runs with disjoint seeds (T3)\n        # draw disjoint samples while keeping the spec-pinned cache key formula.\n        sample_index = config.seed * config.n_samples + i\n        key = sample_key(\n            config.reference_model, config.temperature, config.max_tokens, artifact_text, sample_index\n        )\n        cached = cache.get(\"samples\", key)\n        if cached is not None:\n            text = cached[\"text\"]\n        else:\n            text = client.complete(\n                model=config.reference_model,\n                prompt=artifact_text,\n                temperature=config.temperature,\n                max_tokens=config.max_tokens,\n                seed=sample_index,\n            )\n            cache.put(\n                \"samples\",\n                key,\n                {\n                    \"text\": text,\n                    \"reference_model\": config.reference_model,\n                    \"temperature\": config.temperature,\n                    \"max_tokens\": config.max_tokens,\n                    \"sample_index\": sample_index,\n                },\n            )\n        samples.append(text)\n",
          "kind": "for",
          "span": {
            "start_line": 59,
            "end_line": 88
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0023",
          "text": "    return SampleSet(\n        artifact_text=artifact_text,\n        samples=samples,\n        refusal_flags=[is_refusal(s) for s in samples],\n    )\n",
          "kind": "return",
          "span": {
            "start_line": 89,
            "end_line": 93
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        }
      ],
