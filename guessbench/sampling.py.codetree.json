            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0015",
          "text": "\n    artifact_text: str\n",
          "kind": "assign",
          "span": {
            "start_line": 41,
            "end_line": 42
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0016",
          "text": "    samples: list[str]\n",
          "kind": "assign",
          "span": {
            "start_line": 43,
            "end_line": 43
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0017",
          "text": "    refusal_flags: list[bool]\n",
          "kind": "assign",
          "span": {
            "start_line": 44,
            "end_line": 44
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "scope",
          "id": "sc-0003",
          "kind": "function",
          "name": "refusal_fraction",
          "header_text": "\n    @property\n    def refusal_fraction(self) -> float:\n",
          "span": {
            "start_line": 45,
            "end_line": 48
          },
          "body": [
            {
              "type": "statement",
              "id": "st-0018",
              "text": "        return sum(self.refusal_flags) / len(self.samples) if self.samples else 0.0\n",
              "kind": "return",
              "span": {
                "start_line": 48,
                "end_line": 48
              },
              "authored_by": "Adam Conway",
              "authored_at": "2026-07-02T02:43:03Z",
              "author_type": "human",
              "authorship_context": {
                "commit": "97836b7825606e28d73cd124115b163278273a35",
                "commit_summary": "Initial commit"
              }
            }
          ],
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "scope",
          "id": "sc-0004",
          "kind": "function",
          "name": "low_confidence",
          "header_text": "\n    @property\n    def low_confidence(self) -> bool:\n",
          "span": {
            "start_line": 49,
            "end_line": 52
          },
          "body": [
            {
              "type": "statement",
              "id": "st-0019",
              "text": "        return self.refusal_fraction > 0.20\n",
              "kind": "return",
              "span": {
                "start_line": 52,
                "end_line": 52
              },
              "authored_by": "Adam Conway",
              "authored_at": "2026-07-02T02:43:03Z",
              "author_type": "human",
              "authorship_context": {
                "commit": "97836b7825606e28d73cd124115b163278273a35",
                "commit_summary": "Initial commit"
              }
            }
          ],
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        }
      ],
      "authored_by": "Adam Conway",
      "authored_at": "2026-07-02T02:43:03Z",
      "author_type": "human",
      "authorship_context": {
