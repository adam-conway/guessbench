    {
      "type": "statement",
      "id": "st-0008",
      "text": "\n# Heuristic refusal / meta-response detection (SPEC 9). Refusals still cluster\n# like any other sample; this only feeds the report's refusal fraction.\n_REFUSAL_PATTERNS = [\n    r\"\\bI (?:can'?not|can'?t|won'?t|am (?:not able|unable)) (?:to )?(?:help|assist|comply|do|write|provide|fulfill)\",\n    r\"\\bI'?m sorry,? (?:but )?I (?:can'?not|can'?t)\",\n    r\"\\bI must (?:decline|refuse)\\b\",\n    r\"\\bas an AI\\b.{0,60}\\b(?:can'?not|can'?t|unable)\\b\",\n]\n",
      "kind": "assign",
      "span": {
        "start_line": 11,
        "end_line": 19
      },
      "authored_by": "Adam Conway",
      "authored_at": "2026-07-02T02:43:03Z",
      "author_type": "human",
      "authorship_context": {
        "commit": "97836b7825606e28d73cd124115b163278273a35",
        "commit_summary": "Initial commit"
      }
    },
    {
      "type": "statement",
      "id": "st-0009",
      "text": "_CLARIFICATION_PATTERNS = [\n    r\"\\b(?:could|can|would) you (?:please )?(?:clarify|specify|provide more|tell me more)\\b\",\n    r\"\\bbefore I (?:can )?(?:help|proceed|answer|start)\\b.{0,80}\\?\",\n    r\"\\b(?:what|which) (?:kind|type|sort) of\\b.{0,80}\\?\\s*$\",\n    r\"\\bI need (?:a bit )?more (?:information|details|context)\\b\",\n]\n",
      "kind": "assign",
      "span": {
        "start_line": 20,
        "end_line": 25
      },
      "authored_by": "Adam Conway",
      "authored_at": "2026-07-02T02:43:03Z",
      "author_type": "human",
      "authorship_context": {
        "commit": "97836b7825606e28d73cd124115b163278273a35",
        "commit_summary": "Initial commit"
      }
    },
    {
      "type": "scope",
      "id": "sc-0001",
      "kind": "function",
      "name": "is_refusal",
      "header_text": "\n\ndef is_refusal(text: str) -> bool:\n",
      "span": {
        "start_line": 26,
        "end_line": 35
      },
      "body": [
        {
          "type": "statement",
          "id": "st-0010",
          "text": "    \"\"\"True if the sample declines the task or asks a clarifying question instead\n    of completing it.\"\"\"\n",
          "kind": "docstring",
          "span": {
            "start_line": 29,
            "end_line": 30
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0011",
          "text": "    head = text.strip()[:500]\n",
          "kind": "assign",
          "span": {
            "start_line": 31,
            "end_line": 31
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0012",
          "text": "    for pattern in _REFUSAL_PATTERNS + _CLARIFICATION_PATTERNS:\n        if re.search(pattern, head, flags=re.IGNORECASE):\n            return True\n",
          "kind": "for",
          "span": {
            "start_line": 32,
            "end_line": 34
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0013",
          "text": "    return False\n",
          "kind": "return",
          "span": {
            "start_line": 35,
            "end_line": 35
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        }
      ],
      "authored_by": "Adam Conway",
      "authored_at": "2026-07-02T02:43:03Z",
      "author_type": "human",
      "authorship_context": {
        "commit": "97836b7825606e28d73cd124115b163278273a35",
        "commit_summary": "Initial commit"
      }
    },
    {
      "type": "scope",
      "id": "sc-0002",
      "kind": "class",
      "name": "SampleSet",
      "header_text": "\n\n@dataclass\nclass SampleSet:\n",
      "span": {
        "start_line": 36,
        "end_line": 52
      },
      "body": [
        {
          "type": "statement",
          "id": "st-0014",
          "text": "    \"\"\"N completions of one artifact plus refusal accounting.\"\"\"\n",
          "kind": "docstring",
          "span": {
            "start_line": 40,
            "end_line": 40
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
