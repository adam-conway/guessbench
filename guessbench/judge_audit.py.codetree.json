          "id": "st-0033",
          "text": "    key_path.write_text(json.dumps(answer_key, indent=2, ensure_ascii=False), encoding=\"utf-8\")\n",
          "kind": "expr",
          "span": {
            "start_line": 107,
            "end_line": 107
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0034",
          "text": "    return sheet_path, key_path\n",
          "kind": "return",
          "span": {
            "start_line": 108,
            "end_line": 108
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
