          }
        }
      ],
      "authored_by": "Adam Conway",
      "authored_at": "2026-07-02T02:43:03Z",
      "author_type": "human",
      "authorship_context": {
        "commit": "97836b7825606e28d73cd124115b163278273a35",
        "commit_summary": "Initial commit"
      }
    },
    {
      "type": "scope",
      "id": "sc-0002",
      "kind": "function",
      "name": "select_audit_pairs",
      "header_text": "\n\ndef select_audit_pairs(\n    artifacts: dict[str, dict],\n    config: RunConfig,\n    client: ModelClient,\n    cache: Cache,\n    per_stratum: int = 10,\n    seed: int = 0,\n) -> list[dict]:\n",
      "span": {
        "start_line": 24,
        "end_line": 79
      },
      "body": [
        {
          "type": "statement",
          "id": "st-0012",
          "text": "    \"\"\"Stratified pair selection (SPEC 6 T5): ~10 same-cluster, ~10 cross-cluster,\n    ~10 near-boundary (closest cross-cluster pairs by embedding distance).\n\n    `artifacts` maps artifact_id -> {\"text\", \"samples\", \"assignments\"}.\n    \"\"\"\n",
          "kind": "docstring",
          "span": {
            "start_line": 34,
            "end_line": 38
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0013",
          "text": "    rng = random.Random(seed)\n",
          "kind": "assign",
          "span": {
            "start_line": 39,
            "end_line": 39
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0014",
          "text": "    same_cluster: list[dict] = []\n",
          "kind": "assign",
          "span": {
            "start_line": 40,
            "end_line": 40
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0015",
          "text": "    cross_cluster: list[dict] = []\n",
          "kind": "assign",
          "span": {
            "start_line": 41,
            "end_line": 41
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0016",
          "text": "\n    for artifact_id, art in artifacts.items():\n        assignments = art[\"assignments\"]\n        vectors = get_embeddings(art[\"samples\"], config, client, cache)\n        norms = np.linalg.norm(vectors, axis=1, keepdims=True)\n        normalized = vectors / np.where(norms == 0, 1, norms)\n        distances = 1 - normalized @ normalized.T\n        n = len(assignments)\n        for i in range(n):\n            for j in range(i + 1, n):\n                pair = {\n                    \"pair_id\": _pair_id(artifact_id, i, j),\n                    \"artifact_id\": artifact_id,\n                    \"artifact_text\": art[\"text\"],\n                    \"output_a\": art[\"samples\"][i],\n                    \"output_b\": art[\"samples\"][j],\n                    \"same_cluster\": assignments[i] == assignments[j],\n                    \"distance\": float(distances[i, j]),\n                }\n                (same_cluster if pair[\"same_cluster\"] else cross_cluster).append(pair)\n",
          "kind": "for",
          "span": {
            "start_line": 42,
            "end_line": 61
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0017",
          "text": "\n    rng.shuffle(same_cluster)\n",
          "kind": "expr",
          "span": {
            "start_line": 62,
            "end_line": 63
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0018",
          "text": "    rng.shuffle(cross_cluster)\n",
          "kind": "expr",
          "span": {
            "start_line": 64,
            "end_line": 64
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0019",
          "text": "    # Near-boundary: closest cross-cluster pairs by embedding distance.\n    near_boundary = sorted(cross_cluster, key=lambda p: p[\"distance\"])[:per_stratum]\n",
          "kind": "assign",
          "span": {
            "start_line": 65,
            "end_line": 66
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0020",
          "text": "    boundary_ids = {p[\"pair_id\"] for p in near_boundary}\n",
          "kind": "assign",
          "span": {
            "start_line": 67,
            "end_line": 67
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0021",
          "text": "    plain_cross = [p for p in cross_cluster if p[\"pair_id\"] not in boundary_ids][:per_stratum]\n",
          "kind": "assign",
          "span": {
            "start_line": 68,
            "end_line": 68
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0022",
          "text": "\n    selected = same_cluster[:per_stratum] + plain_cross + near_boundary\n",
          "kind": "assign",
          "span": {
            "start_line": 69,
            "end_line": 70
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0023",
          "text": "    for pair, stratum in zip(\n        selected,\n        [\"same_cluster\"] * len(same_cluster[:per_stratum])\n        + [\"cross_cluster\"] * len(plain_cross)\n        + [\"near_boundary\"] * len(near_boundary),\n    ):\n        pair[\"stratum\"] = stratum\n",
          "kind": "for",
          "span": {
            "start_line": 71,
            "end_line": 77
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0024",
          "text": "    rng.shuffle(selected)\n",
          "kind": "expr",
          "span": {
            "start_line": 78,
            "end_line": 78
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0025",
          "text": "    return selected\n",
          "kind": "return",
          "span": {
            "start_line": 79,
            "end_line": 79
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        }
      ],
      "authored_by": "Adam Conway",
      "authored_at": "2026-07-02T02:43:03Z",
      "author_type": "human",
      "authorship_context": {
        "commit": "97836b7825606e28d73cd124115b163278273a35",
        "commit_summary": "Initial commit"
      }
    },
    {
      "type": "scope",
      "id": "sc-0003",
      "kind": "function",
      "name": "write_audit_export",
      "header_text": "\n\ndef write_audit_export(pairs: list[dict], out_dir: Path) -> tuple[Path, Path]:\n",
      "span": {
        "start_line": 80,
        "end_line": 108
      },
      "body": [
        {
          "type": "statement",
          "id": "st-0026",
          "text": "    \"\"\"Write the blind labeling sheet and the separate answer key.\"\"\"\n",
          "kind": "docstring",
          "span": {
            "start_line": 83,
            "end_line": 83
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0027",
          "text": "    out_dir.mkdir(parents=True, exist_ok=True)\n",
          "kind": "expr",
          "span": {
            "start_line": 84,
            "end_line": 84
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0028",
          "text": "    labeling_sheet = [\n        {\n            \"pair_id\": p[\"pair_id\"],\n            \"artifact_text\": p[\"artifact_text\"],\n            \"output_a\": p[\"output_a\"],\n            \"output_b\": p[\"output_b\"],\n            \"human_label\": \"\",  # fill with INTERCHANGEABLE or DIFFERENT\n        }\n        for p in pairs\n    ]\n",
          "kind": "assign",
          "span": {
            "start_line": 85,
            "end_line": 94
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0029",
          "text": "    answer_key = [\n        {\n            \"pair_id\": p[\"pair_id\"],\n            \"strategy_verdict\": \"INTERCHANGEABLE\" if p[\"same_cluster\"] else \"DIFFERENT\",\n            \"stratum\": p[\"stratum\"],\n            \"distance\": p[\"distance\"],\n        }\n        for p in pairs\n    ]\n",
          "kind": "assign",
          "span": {
            "start_line": 95,
            "end_line": 103
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0030",
          "text": "    sheet_path = out_dir / \"t5_labeling_sheet.json\"\n",
          "kind": "assign",
          "span": {
            "start_line": 104,
            "end_line": 104
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
