      }
    },
    {
      "type": "statement",
      "id": "st-0008",
      "text": "from guessbench.config import RunConfig\n",
      "kind": "import",
      "span": {
        "start_line": 17,
        "end_line": 17
      },
      "authored_by": "Adam Conway",
      "authored_at": "2026-07-02T02:43:03Z",
