      }
    },
    {
      "type": "statement",
      "id": "st-0010",
      "text": "from guessbench.strategies.embedding import get_embeddings\n",
      "kind": "import",
      "span": {
        "start_line": 19,
        "end_line": 19
      },
      "authored_by": "Adam Conway",
      "authored_at": "2026-07-02T02:43:03Z",
