        {
          "type": "statement",
          "id": "st-0032",
          "text": "    sheet_path.write_text(json.dumps(labeling_sheet, indent=2, ensure_ascii=False), encoding=\"utf-8\")\n",
          "kind": "expr",
          "span": {
