      }
    },
    {
      "type": "scope",
      "id": "sc-0001",
      "kind": "function",
      "name": "_pair_id",
      "header_text": "\n\ndef _pair_id(artifact_id: str, i: int, j: int) -> str:\n",
      "span": {
        "start_line": 20,
        "end_line": 23
      },
      "body": [
        {
          "type": "statement",
          "id": "st-0011",
          "text": "    return f\"{artifact_id}:{min(i, j)}-{max(i, j)}\"\n",
          "kind": "return",
          "span": {
            "start_line": 23,
            "end_line": 23
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
