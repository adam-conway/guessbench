    {
      "type": "scope",
      "id": "sc-0004",
      "kind": "function",
      "name": "cohens_kappa",
      "header_text": "\n\ndef cohens_kappa(labels_a: list[str], labels_b: list[str]) -> float:\n",
      "span": {
        "start_line": 109,
        "end_line": 123
      },
      "body": [
        {
          "type": "statement",
          "id": "st-0035",
          "text": "    \"\"\"Cohen's kappa for two binary raters.\"\"\"\n",
          "kind": "docstring",
          "span": {
            "start_line": 112,
            "end_line": 112
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0036",
          "text": "    if len(labels_a) != len(labels_b) or not labels_a:\n        raise ValueError(\"label lists must be equal-length and non-empty\")\n",
          "kind": "if",
          "span": {
            "start_line": 113,
            "end_line": 114
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0037",
          "text": "    n = len(labels_a)\n",
          "kind": "assign",
          "span": {
            "start_line": 115,
            "end_line": 115
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0038",
          "text": "    observed = sum(a == b for a, b in zip(labels_a, labels_b)) / n\n",
          "kind": "assign",
          "span": {
            "start_line": 116,
            "end_line": 116
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0039",
          "text": "    categories = set(labels_a) | set(labels_b)\n",
          "kind": "assign",
          "span": {
            "start_line": 117,
            "end_line": 117
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0040",
          "text": "    expected = sum(\n        (labels_a.count(c) / n) * (labels_b.count(c) / n) for c in categories\n    )\n",
          "kind": "assign",
          "span": {
            "start_line": 118,
            "end_line": 120
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0041",
          "text": "    if expected == 1.0:\n        return 1.0\n",
          "kind": "if",
          "span": {
            "start_line": 121,
            "end_line": 122
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0042",
          "text": "    return (observed - expected) / (1 - expected)\n",
          "kind": "return",
          "span": {
            "start_line": 123,
            "end_line": 123
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        }
      ],
      "authored_by": "Adam Conway",
      "authored_at": "2026-07-02T02:43:03Z",
      "author_type": "human",
      "authorship_context": {
        "commit": "97836b7825606e28d73cd124115b163278273a35",
        "commit_summary": "Initial commit"
      }
    },
    {
      "type": "scope",
      "id": "sc-0005",
      "kind": "function",
      "name": "compute_kappa_from_files",
      "header_text": "\n\ndef compute_kappa_from_files(labeled_sheet_path: Path, answer_key_path: Path) -> dict:\n",
      "span": {
        "start_line": 124,
        "end_line": 149
      },
      "body": [
        {
          "type": "statement",
          "id": "st-0043",
          "text": "    \"\"\"Join human labels to strategy verdicts by pair_id and compute kappa (T5:\n    pass at kappa >= 0.7).\"\"\"\n",
          "kind": "docstring",
          "span": {
            "start_line": 127,
            "end_line": 128
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0044",
          "text": "    sheet = json.loads(labeled_sheet_path.read_text(encoding=\"utf-8\"))\n",
          "kind": "assign",
          "span": {
            "start_line": 129,
            "end_line": 129
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0045",
          "text": "    key = {row[\"pair_id\"]: row for row in json.loads(answer_key_path.read_text(encoding=\"utf-8\"))}\n",
          "kind": "assign",
          "span": {
            "start_line": 130,
            "end_line": 130
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0046",
          "text": "\n    human, strategy = [], []\n",
          "kind": "assign",
          "span": {
            "start_line": 131,
            "end_line": 132
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0047",
          "text": "    skipped = []\n",
          "kind": "assign",
          "span": {
            "start_line": 133,
            "end_line": 133
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0048",
          "text": "    for row in sheet:\n        label = row.get(\"human_label\", \"\").strip().upper()\n        if label not in (\"INTERCHANGEABLE\", \"DIFFERENT\"):\n            skipped.append(row[\"pair_id\"])\n            continue\n        human.append(label)\n        strategy.append(key[row[\"pair_id\"]][\"strategy_verdict\"])\n",
          "kind": "for",
          "span": {
            "start_line": 134,
            "end_line": 140
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0049",
          "text": "\n    kappa = cohens_kappa(human, strategy)\n",
          "kind": "assign",
          "span": {
            "start_line": 141,
            "end_line": 142
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0050",
          "text": "    return {\n        \"kappa\": round(kappa, 4),\n        \"n_labeled\": len(human),\n        \"n_skipped\": len(skipped),\n        \"skipped_pair_ids\": skipped,\n        \"passed\": kappa >= 0.7,\n    }\n",
          "kind": "return",
          "span": {
            "start_line": 143,
            "end_line": 149
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        }
      ],
      "authored_by": "Adam Conway",
      "authored_at": "2026-07-02T02:43:03Z",
      "author_type": "human",
      "authorship_context": {
        "commit": "97836b7825606e28d73cd124115b163278273a35",
        "commit_summary": "Initial commit"
      }
    }
  ]
}
