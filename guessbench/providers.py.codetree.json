          }
        },
        {
          "type": "scope",
          "id": "sc-0009",
          "kind": "function",
          "name": "__init__",
          "header_text": "\n    def __init__(self, api_key: str | None = None, timeout: float = 300.0) -> None:\n",
          "span": {
            "start_line": 58,
            "end_line": 61
          },
          "body": [
            {
              "type": "statement",
              "id": "st-0023",
              "text": "        self.api_key = api_key or os.environ.get(\"ANTHROPIC_API_KEY\", \"\")\n",
              "kind": "assign",
              "span": {
                "start_line": 60,
                "end_line": 60
              },
              "authored_by": "Adam Conway",
              "authored_at": "2026-07-02T02:43:03Z",
              "author_type": "human",
              "authorship_context": {
                "commit": "97836b7825606e28d73cd124115b163278273a35",
                "commit_summary": "Initial commit"
              }
            },
            {
              "type": "statement",
              "id": "st-0024",
              "text": "        self._http = httpx.Client(timeout=timeout)\n",
              "kind": "assign",
              "span": {
                "start_line": 61,
                "end_line": 61
              },
              "authored_by": "Adam Conway",
              "authored_at": "2026-07-02T02:43:03Z",
              "author_type": "human",
              "authorship_context": {
                "commit": "97836b7825606e28d73cd124115b163278273a35",
                "commit_summary": "Initial commit"
              }
            }
          ],
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "scope",
          "id": "sc-0010",
          "kind": "function",
          "name": "complete",
          "header_text": "\n    def complete(self, model: str, prompt: str, temperature: float, max_tokens: int, seed: int | None = None) -> str:\n        # The Messages API has no seed parameter; independence comes from sampling.\n",
          "span": {
            "start_line": 62,
            "end_line": 79
          },
          "body": [
            {
              "type": "statement",
              "id": "st-0025",
              "text": "        resp = self._http.post(\n            \"https://api.anthropic.com/v1/messages\",\n            headers={\n                \"x-api-key\": self.api_key,\n                \"anthropic-version\": \"2023-06-01\",\n            },\n            json={\n                \"model\": model,\n                \"max_tokens\": max_tokens,\n                \"temperature\": temperature,\n                \"messages\": [{\"role\": \"user\", \"content\": prompt}],\n            },\n        )\n",
              "kind": "assign",
              "span": {
                "start_line": 65,
                "end_line": 77
              },
              "authored_by": "Adam Conway",
              "authored_at": "2026-07-02T02:43:03Z",
              "author_type": "human",
              "authorship_context": {
                "commit": "97836b7825606e28d73cd124115b163278273a35",
                "commit_summary": "Initial commit"
              }
            },
            {
              "type": "statement",
              "id": "st-0026",
              "text": "        resp.raise_for_status()\n",
              "kind": "expr",
              "span": {
                "start_line": 78,
                "end_line": 78
              },
              "authored_by": "Adam Conway",
              "authored_at": "2026-07-02T02:43:03Z",
              "author_type": "human",
              "authorship_context": {
                "commit": "97836b7825606e28d73cd124115b163278273a35",
                "commit_summary": "Initial commit"
              }
            },
            {
              "type": "statement",
              "id": "st-0027",
              "text": "        return \"\".join(block[\"text\"] for block in resp.json()[\"content\"] if block[\"type\"] == \"text\")\n",
              "kind": "return",
              "span": {
                "start_line": 79,
                "end_line": 79
              },
              "authored_by": "Adam Conway",
              "authored_at": "2026-07-02T02:43:03Z",
              "author_type": "human",
              "authorship_context": {
                "commit": "97836b7825606e28d73cd124115b163278273a35",
                "commit_summary": "Initial commit"
              }
            }
          ],
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
