      "body": [
        {
          "type": "statement",
          "id": "st-0022",
          "text": "    \"\"\"Client for the Anthropic Messages API (completions only; Anthropic has no\n    embeddings endpoint, so pair with Ollama or another provider for Strategy B).\"\"\"\n",
          "kind": "docstring",
          "span": {
            "start_line": 56,
            "end_line": 57
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
