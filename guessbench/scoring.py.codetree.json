      "name": "entropy_nats",
      "header_text": "\n\ndef entropy_nats(assignments: list[int]) -> float:\n",
      "span": {
        "start_line": 9,
        "end_line": 18
      },
      "body": [
        {
          "type": "statement",
          "id": "st-0006",
          "text": "    \"\"\"Shannon entropy in nats over cluster proportions.\"\"\"\n",
          "kind": "docstring",
          "span": {
            "start_line": 12,
            "end_line": 12
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0007",
          "text": "    n = len(assignments)\n",
          "kind": "assign",
          "span": {
            "start_line": 13,
            "end_line": 13
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0008",
          "text": "    if n == 0:\n        return 0.0\n",
          "kind": "if",
          "span": {
            "start_line": 14,
            "end_line": 15
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0009",
          "text": "    counts = np.array(list(Counter(assignments).values()), dtype=float)\n",
          "kind": "assign",
          "span": {
            "start_line": 16,
            "end_line": 16
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0010",
          "text": "    p = counts / n\n",
          "kind": "assign",
          "span": {
            "start_line": 17,
            "end_line": 17
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0011",
          "text": "    return float(-np.sum(p * np.log(p)))\n",
          "kind": "return",
          "span": {
            "start_line": 18,
            "end_line": 18
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        }
      ],
      "authored_by": "Adam Conway",
      "authored_at": "2026-07-02T02:43:03Z",
      "author_type": "human",
      "authorship_context": {
        "commit": "97836b7825606e28d73cd124115b163278273a35",
        "commit_summary": "Initial commit"
      }
    },
    {
      "type": "scope",
      "id": "sc-0002",
      "kind": "function",
      "name": "effective_interpretations",
      "header_text": "\n\ndef effective_interpretations(assignments: list[int]) -> float:\n",
      "span": {
        "start_line": 19,
        "end_line": 23
      },
      "body": [
        {
          "type": "statement",
          "id": "st-0012",
          "text": "    \"\"\"EI = e^H. Range [1, N]: 1.0 when all samples share a cluster, N when all distinct.\"\"\"\n",
          "kind": "docstring",
          "span": {
            "start_line": 22,
            "end_line": 22
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0013",
          "text": "    return float(np.exp(entropy_nats(assignments)))\n",
          "kind": "return",
          "span": {
            "start_line": 23,
            "end_line": 23
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
