            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0018",
          "text": "    k: int\n",
          "kind": "assign",
          "span": {
            "start_line": 32,
            "end_line": 32
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
