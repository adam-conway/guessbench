    {
      "type": "scope",
      "id": "sc-0004",
      "kind": "function",
      "name": "bootstrap_ci",
      "header_text": "\n\ndef bootstrap_ci(assignments: list[int], iterations: int = 1000, seed: int = 0) -> tuple[float, float]:\n",
      "span": {
        "start_line": 34,
        "end_line": 47
      },
      "body": [
        {
          "type": "statement",
          "id": "st-0020",
          "text": "    \"\"\"90% bootstrap CI on EI: resample cluster assignments with replacement,\n    recompute EI, take 5th/95th percentiles (SPEC 2.3).\"\"\"\n",
          "kind": "docstring",
          "span": {
            "start_line": 37,
            "end_line": 38
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0021",
          "text": "    rng = np.random.default_rng(seed)\n",
          "kind": "assign",
          "span": {
            "start_line": 39,
            "end_line": 39
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0022",
          "text": "    arr = np.array(assignments)\n",
          "kind": "assign",
          "span": {
            "start_line": 40,
            "end_line": 40
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0023",
          "text": "    n = len(arr)\n",
          "kind": "assign",
          "span": {
            "start_line": 41,
            "end_line": 41
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0024",
          "text": "    eis = np.empty(iterations)\n",
          "kind": "assign",
          "span": {
            "start_line": 42,
            "end_line": 42
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0025",
          "text": "    for b in range(iterations):\n        resampled = arr[rng.integers(0, n, size=n)]\n        eis[b] = effective_interpretations(resampled.tolist())\n",
          "kind": "for",
          "span": {
            "start_line": 43,
            "end_line": 45
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0026",
          "text": "    low, high = np.percentile(eis, [5, 95])\n",
          "kind": "assign",
          "span": {
            "start_line": 46,
            "end_line": 46
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0027",
          "text": "    return float(low), float(high)\n",
          "kind": "return",
          "span": {
            "start_line": 47,
            "end_line": 47
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        }
      ],
      "authored_by": "Adam Conway",
      "authored_at": "2026-07-02T02:43:03Z",
      "author_type": "human",
      "authorship_context": {
        "commit": "97836b7825606e28d73cd124115b163278273a35",
        "commit_summary": "Initial commit"
      }
    },
    {
      "type": "scope",
      "id": "sc-0005",
      "kind": "function",
      "name": "score_assignments",
      "header_text": "\n\ndef score_assignments(assignments: list[int], bootstrap_iterations: int = 1000, seed: int = 0) -> Score:\n",
      "span": {
        "start_line": 48,
        "end_line": 60
      },
      "body": [
        {
          "type": "statement",
          "id": "st-0028",
          "text": "    h = entropy_nats(assignments)\n",
          "kind": "assign",
          "span": {
            "start_line": 51,
            "end_line": 51
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0029",
          "text": "    ci_low, ci_high = bootstrap_ci(assignments, iterations=bootstrap_iterations, seed=seed)\n",
          "kind": "assign",
          "span": {
            "start_line": 52,
            "end_line": 52
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0030",
          "text": "    return Score(\n        ei=float(np.exp(h)),\n        ei_ci_low=ci_low,\n        ei_ci_high=ci_high,\n        entropy=h,\n        k=len(set(assignments)),\n        n=len(assignments),\n    )\n",
          "kind": "return",
          "span": {
            "start_line": 53,
            "end_line": 60
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        }
      ],
      "authored_by": "Adam Conway",
      "authored_at": "2026-07-02T02:43:03Z",
      "author_type": "human",
      "authorship_context": {
        "commit": "97836b7825606e28d73cd124115b163278273a35",
        "commit_summary": "Initial commit"
      }
