    {
      "type": "statement",
      "id": "st-0004",
      "text": "import re\n",
      "kind": "import",
      "span": {
        "start_line": 6,
        "end_line": 6
      },
      "authored_by": "Adam Conway",
      "authored_at": "2026-07-02T02:43:03Z",
