    },
    {
      "type": "statement",
      "id": "st-0003",
      "text": "\nimport numpy as np\n",
      "kind": "import",
      "span": {
        "start_line": 4,
        "end_line": 5
      },
      "authored_by": "Adam Conway",
      "authored_at": "2026-07-02T02:43:03Z",
      "author_type": "human",
      "authorship_context": {
        "commit": "97836b7825606e28d73cd124115b163278273a35",
        "commit_summary": "Initial commit"
      }
    },
    {
      "type": "statement",
      "id": "st-0004",
      "text": "from sklearn.cluster import AgglomerativeClustering\n",
      "kind": "import",
      "span": {
        "start_line": 6,
        "end_line": 6
      },
      "authored_by": "Adam Conway",
      "authored_at": "2026-07-02T02:43:03Z",
      "author_type": "human",
      "authorship_context": {
        "commit": "97836b7825606e28d73cd124115b163278273a35",
        "commit_summary": "Initial commit"
      }
    },
    {
      "type": "statement",
      "id": "st-0005",
      "text": "\nfrom guessbench.cache import Cache, embedding_key\n",
      "kind": "import",
      "span": {
        "start_line": 7,
        "end_line": 8
      },
      "authored_by": "Adam Conway",
      "authored_at": "2026-07-02T02:43:03Z",
      "author_type": "human",
      "authorship_context": {
        "commit": "97836b7825606e28d73cd124115b163278273a35",
        "commit_summary": "Initial commit"
      }
    },
    {
      "type": "statement",
      "id": "st-0006",
      "text": "from guessbench.config import RunConfig\n",
      "kind": "import",
      "span": {
        "start_line": 9,
        "end_line": 9
      },
      "authored_by": "Adam Conway",
      "authored_at": "2026-07-02T02:43:03Z",
      "author_type": "human",
      "authorship_context": {
        "commit": "97836b7825606e28d73cd124115b163278273a35",
        "commit_summary": "Initial commit"
      }
    },
    {
      "type": "statement",
      "id": "st-0007",
      "text": "from guessbench.providers import ModelClient\n",
      "kind": "import",
      "span": {
        "start_line": 10,
        "end_line": 10
      },
      "authored_by": "Adam Conway",
      "authored_at": "2026-07-02T02:43:03Z",
      "author_type": "human",
      "authorship_context": {
        "commit": "97836b7825606e28d73cd124115b163278273a35",
        "commit_summary": "Initial commit"
      }
    },
    {
      "type": "statement",
      "id": "st-0008",
      "text": "from guessbench.strategies.base import ClusteringResult, EquivalenceStrategy\n",
      "kind": "import",
      "span": {
        "start_line": 11,
        "end_line": 11
      },
      "authored_by": "Adam Conway",
      "authored_at": "2026-07-02T02:43:03Z",
      "author_type": "human",
      "authorship_context": {
        "commit": "97836b7825606e28d73cd124115b163278273a35",
        "commit_summary": "Initial commit"
      }
    },
    {
      "type": "scope",
      "id": "sc-0001",
      "kind": "function",
      "name": "get_embeddings",
      "header_text": "\n\ndef get_embeddings(\n    texts: list[str], config: RunConfig, client: ModelClient, cache: Cache\n) -> np.ndarray:\n",
      "span": {
        "start_line": 12,
        "end_line": 28
      },
      "body": [
        {
          "type": "statement",
          "id": "st-0009",
          "text": "    \"\"\"Embed each text, content-addressed cached per (embedding_model, text).\"\"\"\n",
          "kind": "docstring",
          "span": {
            "start_line": 17,
            "end_line": 17
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0010",
          "text": "    vectors = []\n",
          "kind": "assign",
          "span": {
            "start_line": 18,
            "end_line": 18
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0011",
          "text": "    for text in texts:\n        key = embedding_key(config.embedding_model, text)\n        cached = cache.get(\"embeddings\", key)\n        if cached is not None:\n            vec = cached[\"vector\"]\n        else:\n            vec = client.embed(model=config.embedding_model, text=text)\n            cache.put(\"embeddings\", key, {\"vector\": vec, \"embedding_model\": config.embedding_model})\n        vectors.append(vec)\n",
          "kind": "for",
          "span": {
            "start_line": 19,
            "end_line": 27
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0012",
          "text": "    return np.array(vectors, dtype=float)\n",
          "kind": "return",
          "span": {
            "start_line": 28,
            "end_line": 28
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        }
      ],
      "authored_by": "Adam Conway",
      "authored_at": "2026-07-02T02:43:03Z",
      "author_type": "human",
      "authorship_context": {
        "commit": "97836b7825606e28d73cd124115b163278273a35",
        "commit_summary": "Initial commit"
      }
    },
    {
      "type": "scope",
      "id": "sc-0002",
      "kind": "function",
      "name": "cluster_vectors",
      "header_text": "\n\ndef cluster_vectors(vectors: np.ndarray, threshold: float) -> list[int]:\n",
      "span": {
        "start_line": 29,
        "end_line": 41
      },
      "body": [
        {
          "type": "statement",
          "id": "st-0013",
          "text": "    \"\"\"Agglomerative clustering (average linkage, cosine distance) cut at the threshold.\"\"\"\n",
          "kind": "docstring",
          "span": {
            "start_line": 32,
            "end_line": 32
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0014",
          "text": "    if len(vectors) == 1:\n        return [0]\n",
          "kind": "if",
          "span": {
            "start_line": 33,
            "end_line": 34
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0015",
          "text": "    model = AgglomerativeClustering(\n        n_clusters=None,\n        distance_threshold=threshold,\n        metric=\"cosine\",\n        linkage=\"average\",\n    )\n",
          "kind": "assign",
          "span": {
            "start_line": 35,
            "end_line": 40
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0016",
          "text": "    return model.fit_predict(vectors).tolist()\n",
          "kind": "return",
          "span": {
            "start_line": 41,
            "end_line": 41
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        }
      ],
      "authored_by": "Adam Conway",
      "authored_at": "2026-07-02T02:43:03Z",
      "author_type": "human",
      "authorship_context": {
        "commit": "97836b7825606e28d73cd124115b163278273a35",
        "commit_summary": "Initial commit"
      }
    },
    {
      "type": "scope",
      "id": "sc-0003",
      "kind": "class",
      "name": "EmbeddingStrategy",
      "header_text": "\n\nclass EmbeddingStrategy(EquivalenceStrategy):\n",
      "span": {
        "start_line": 42,
        "end_line": 79
      },
      "body": [
        {
          "type": "statement",
          "id": "st-0017",
          "text": "    strategy_id = \"embedding\"\n",
          "kind": "assign",
          "span": {
            "start_line": 45,
            "end_line": 45
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0018",
          "text": "    version = \"v1\"\n",
          "kind": "assign",
          "span": {
            "start_line": 46,
            "end_line": 46
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "scope",
          "id": "sc-0004",
          "kind": "function",
          "name": "__init__",
          "header_text": "\n    def __init__(self, threshold: float | None = None) -> None:\n        # Falls back to config.embedding_threshold when not set explicitly.\n",
          "span": {
            "start_line": 47,
            "end_line": 50
          },
          "body": [
            {
              "type": "statement",
              "id": "st-0019",
              "text": "        self.threshold = threshold\n",
              "kind": "assign",
              "span": {
                "start_line": 50,
                "end_line": 50
              },
              "authored_by": "Adam Conway",
              "authored_at": "2026-07-02T02:43:03Z",
              "author_type": "human",
              "authorship_context": {
                "commit": "97836b7825606e28d73cd124115b163278273a35",
                "commit_summary": "Initial commit"
              }
            }
          ],
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "scope",
          "id": "sc-0005",
          "kind": "function",
          "name": "cluster",
          "header_text": "\n    def cluster(\n        self,\n        artifact_text: str,\n        samples: list[str],\n        config: RunConfig,\n        client: ModelClient,\n        cache: Cache,\n    ) -> ClusteringResult:\n",
          "span": {
            "start_line": 51,
            "end_line": 79
          },
          "body": [
            {
              "type": "statement",
              "id": "st-0020",
              "text": "        threshold = self.threshold if self.threshold is not None else config.embedding_threshold\n",
              "kind": "assign",
              "span": {
                "start_line": 60,
                "end_line": 60
              },
              "authored_by": "Adam Conway",
              "authored_at": "2026-07-02T02:43:03Z",
              "author_type": "human",
              "authorship_context": {
                "commit": "97836b7825606e28d73cd124115b163278273a35",
                "commit_summary": "Initial commit"
              }
            },
            {
              "type": "statement",
              "id": "st-0021",
              "text": "        vectors = get_embeddings(samples, config, client, cache)\n",
              "kind": "assign",
              "span": {
                "start_line": 61,
                "end_line": 61
              },
              "authored_by": "Adam Conway",
              "authored_at": "2026-07-02T02:43:03Z",
              "author_type": "human",
              "authorship_context": {
                "commit": "97836b7825606e28d73cd124115b163278273a35",
                "commit_summary": "Initial commit"
              }
            },
            {
              "type": "statement",
              "id": "st-0022",
              "text": "        assignments = cluster_vectors(vectors, threshold)\n",
              "kind": "assign",
              "span": {
                "start_line": 62,
                "end_line": 62
              },
              "authored_by": "Adam Conway",
              "authored_at": "2026-07-02T02:43:03Z",
              "author_type": "human",
              "authorship_context": {
                "commit": "97836b7825606e28d73cd124115b163278273a35",
                "commit_summary": "Initial commit"
              }
            },
            {
              "type": "statement",
              "id": "st-0023",
              "text": "\n        # Record pairwise cosine distances for the judge audit's near-boundary\n        # pair selection (T5).\n        norms = np.linalg.norm(vectors, axis=1, keepdims=True)\n",
              "kind": "assign",
              "span": {
                "start_line": 63,
                "end_line": 66
              },
              "authored_by": "Adam Conway",
              "authored_at": "2026-07-02T02:43:03Z",
              "author_type": "human",
              "authorship_context": {
                "commit": "97836b7825606e28d73cd124115b163278273a35",
                "commit_summary": "Initial commit"
              }
            },
            {
              "type": "statement",
              "id": "st-0024",
              "text": "        normalized = vectors / np.where(norms == 0, 1, norms)\n",
              "kind": "assign",
              "span": {
                "start_line": 67,
                "end_line": 67
              },
              "authored_by": "Adam Conway",
              "authored_at": "2026-07-02T02:43:03Z",
              "author_type": "human",
              "authorship_context": {
                "commit": "97836b7825606e28d73cd124115b163278273a35",
                "commit_summary": "Initial commit"
              }
            },
            {
              "type": "statement",
              "id": "st-0025",
              "text": "        distances = 1 - normalized @ normalized.T\n",
              "kind": "assign",
              "span": {
                "start_line": 68,
                "end_line": 68
              },
              "authored_by": "Adam Conway",
              "authored_at": "2026-07-02T02:43:03Z",
              "author_type": "human",
              "authorship_context": {
                "commit": "97836b7825606e28d73cd124115b163278273a35",
                "commit_summary": "Initial commit"
              }
            },
            {
              "type": "statement",
              "id": "st-0026",
              "text": "        pair_records = [\n            {\n                \"sample_i\": i,\n                \"sample_j\": j,\n                \"distance\": float(distances[i, j]),\n                \"same_cluster\": assignments[i] == assignments[j],\n            }\n            for i in range(len(samples))\n            for j in range(i + 1, len(samples))\n        ]\n",
              "kind": "assign",
              "span": {
                "start_line": 69,
                "end_line": 78
              },
              "authored_by": "Adam Conway",
              "authored_at": "2026-07-02T02:43:03Z",
              "author_type": "human",
              "authorship_context": {
                "commit": "97836b7825606e28d73cd124115b163278273a35",
                "commit_summary": "Initial commit"
              }
            },
            {
              "type": "statement",
              "id": "st-0027",
              "text": "        return ClusteringResult(assignments=assignments, pair_records=pair_records)\n",
              "kind": "return",
              "span": {
                "start_line": 79,
                "end_line": 79
              },
              "authored_by": "Adam Conway",
              "authored_at": "2026-07-02T02:43:03Z",
              "author_type": "human",
              "authorship_context": {
                "commit": "97836b7825606e28d73cd124115b163278273a35",
                "commit_summary": "Initial commit"
              }
            }
          ],
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        }
      ],
      "authored_by": "Adam Conway",
      "authored_at": "2026-07-02T02:43:03Z",
      "author_type": "human",
      "authorship_context": {
        "commit": "97836b7825606e28d73cd124115b163278273a35",
        "commit_summary": "Initial commit"
      }
    },
    {
      "type": "scope",
      "id": "sc-0006",
      "kind": "function",
      "name": "sweep_thresholds",
      "header_text": "\n\ndef sweep_thresholds(\n    samples_by_artifact: dict[str, list[str]],\n    thresholds: list[float],\n    config: RunConfig,\n    client: ModelClient,\n    cache: Cache,\n) -> dict[float, dict[str, list[int]]]:\n",
      "span": {
        "start_line": 80,
        "end_line": 104
      },
      "body": [
        {
          "type": "statement",
          "id": "st-0028",
          "text": "    \"\"\"Cluster every artifact's samples at each candidate threshold.\n\n    Embeddings are computed once (cached); only the cut varies. The acceptance\n    suite selects the winning threshold (SPEC 4.3).\n    \"\"\"\n",
          "kind": "docstring",
          "span": {
            "start_line": 89,
            "end_line": 93
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0029",
          "text": "    vectors_by_artifact = {\n        artifact: get_embeddings(samples, config, client, cache)\n        for artifact, samples in samples_by_artifact.items()\n    }\n",
          "kind": "assign",
          "span": {
            "start_line": 94,
            "end_line": 97
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0030",
          "text": "    return {\n        threshold: {\n            artifact: cluster_vectors(vectors, threshold)\n            for artifact, vectors in vectors_by_artifact.items()\n        }\n        for threshold in thresholds\n    }\n",
          "kind": "return",
          "span": {
            "start_line": 98,
            "end_line": 104
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        }
      ],
      "authored_by": "Adam Conway",
      "authored_at": "2026-07-02T02:43:03Z",
      "author_type": "human",
      "authorship_context": {
        "commit": "97836b7825606e28d73cd124115b163278273a35",
        "commit_summary": "Initial commit"
      }
    }
  ]
}
