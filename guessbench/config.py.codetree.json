        },
        {
          "type": "scope",
          "id": "sc-0004",
          "kind": "function",
          "name": "config_hash",
          "header_text": "\n    def config_hash(self) -> str:\n",
          "span": {
            "start_line": 58,
            "end_line": 65
          },
          "body": [
            {
              "type": "statement",
              "id": "st-0036",
              "text": "        \"\"\"Reproducibility hash over the score-affecting configuration.\"\"\"\n",
              "kind": "docstring",
              "span": {
                "start_line": 60,
                "end_line": 60
              },
              "authored_by": "Adam Conway",
              "authored_at": "2026-07-02T02:43:03Z",
              "author_type": "human",
              "authorship_context": {
                "commit": "97836b7825606e28d73cd124115b163278273a35",
                "commit_summary": "Initial commit"
              }
            },
            {
              "type": "statement",
              "id": "st-0037",
              "text": "        d = asdict(self)\n",
              "kind": "assign",
              "span": {
                "start_line": 61,
                "end_line": 61
              },
              "authored_by": "Adam Conway",
              "authored_at": "2026-07-02T02:43:03Z",
              "author_type": "human",
              "authorship_context": {
                "commit": "97836b7825606e28d73cd124115b163278273a35",
                "commit_summary": "Initial commit"
              }
            },
            {
              "type": "statement",
              "id": "st-0038",
              "text": "        # Cache location/usage and endpoint do not affect the score itself.\n        for key in (\"cache_dir\", \"use_cache\", \"ollama_base_url\"):\n            d.pop(key)\n",
              "kind": "for",
              "span": {
                "start_line": 62,
                "end_line": 64
              },
              "authored_by": "Adam Conway",
              "authored_at": "2026-07-02T02:43:03Z",
              "author_type": "human",
