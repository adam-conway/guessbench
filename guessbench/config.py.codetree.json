      "name": "stable_hash",
      "header_text": "\n\ndef stable_hash(*parts: object) -> str:\n",
      "span": {
        "start_line": 23,
        "end_line": 28
      },
      "body": [
        {
          "type": "statement",
          "id": "st-0015",
          "text": "    \"\"\"SHA-256 over a JSON-serialized tuple of parts, hex digest.\"\"\"\n",
          "kind": "docstring",
          "span": {
            "start_line": 26,
            "end_line": 26
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0016",
          "text": "    payload = json.dumps(parts, sort_keys=True, ensure_ascii=False, default=str)\n",
          "kind": "assign",
          "span": {
            "start_line": 27,
            "end_line": 27
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        },
        {
          "type": "statement",
          "id": "st-0017",
          "text": "    return hashlib.sha256(payload.encode(\"utf-8\")).hexdigest()\n",
          "kind": "return",
          "span": {
            "start_line": 28,
            "end_line": 28
          },
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        }
      ],
      "authored_by": "Adam Conway",
      "authored_at": "2026-07-02T02:43:03Z",
      "author_type": "human",
      "authorship_context": {
