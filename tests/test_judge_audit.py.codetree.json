      },
      "body": [
        {
          "type": "scope",
          "id": "sc-0013",
          "kind": "function",
          "name": "test_round_trip",
          "header_text": "    def test_round_trip(self, tmp_cache_dir, tmp_path):\n",
          "span": {
            "start_line": 91,
            "end_line": 112
          },
          "body": [
            {
              "type": "statement",
              "id": "st-0032",
              "text": "        config = RunConfig(cache_dir=tmp_cache_dir)\n",
              "kind": "assign",
              "span": {
                "start_line": 92,
                "end_line": 92
              },
              "authored_by": "Adam Conway",
              "authored_at": "2026-07-02T02:43:03Z",
              "author_type": "human",
              "authorship_context": {
                "commit": "97836b7825606e28d73cd124115b163278273a35",
                "commit_summary": "Initial commit"
              }
            },
            {
              "type": "statement",
              "id": "st-0033",
              "text": "        pairs = select_audit_pairs(\n            make_audit_inputs(), config, FixedEmbedClient(), Cache(tmp_cache_dir), per_stratum=3\n        )\n",
              "kind": "assign",
              "span": {
                "start_line": 93,
                "end_line": 95
              },
              "authored_by": "Adam Conway",
              "authored_at": "2026-07-02T02:43:03Z",
              "author_type": "human",
              "authorship_context": {
                "commit": "97836b7825606e28d73cd124115b163278273a35",
                "commit_summary": "Initial commit"
              }
            },
            {
              "type": "statement",
              "id": "st-0034",
              "text": "        sheet_path, key_path = write_audit_export(pairs, tmp_path / \"audit\")\n",
              "kind": "assign",
              "span": {
                "start_line": 96,
                "end_line": 96
              },
              "authored_by": "Adam Conway",
              "authored_at": "2026-07-02T02:43:03Z",
              "author_type": "human",
              "authorship_context": {
                "commit": "97836b7825606e28d73cd124115b163278273a35",
                "commit_summary": "Initial commit"
              }
            },
            {
              "type": "statement",
              "id": "st-0035",
              "text": "\n        # Human agrees with the strategy on every pair except one, leaves one blank.\n        sheet = json.loads(sheet_path.read_text())\n",
              "kind": "assign",
              "span": {
                "start_line": 97,
                "end_line": 99
              },
              "authored_by": "Adam Conway",
              "authored_at": "2026-07-02T02:43:03Z",
              "author_type": "human",
              "authorship_context": {
                "commit": "97836b7825606e28d73cd124115b163278273a35",
                "commit_summary": "Initial commit"
              }
            },
            {
              "type": "statement",
              "id": "st-0036",
              "text": "        key = {r[\"pair_id\"]: r[\"strategy_verdict\"] for r in json.loads(key_path.read_text())}\n",
              "kind": "assign",
              "span": {
                "start_line": 100,
                "end_line": 100
              },
              "authored_by": "Adam Conway",
              "authored_at": "2026-07-02T02:43:03Z",
              "author_type": "human",
              "authorship_context": {
                "commit": "97836b7825606e28d73cd124115b163278273a35",
                "commit_summary": "Initial commit"
              }
            },
            {
              "type": "statement",
              "id": "st-0037",
              "text": "        for i, row in enumerate(sheet):\n            row[\"human_label\"] = key[row[\"pair_id\"]]\n",
              "kind": "for",
              "span": {
                "start_line": 101,
                "end_line": 102
              },
              "authored_by": "Adam Conway",
              "authored_at": "2026-07-02T02:43:03Z",
              "author_type": "human",
              "authorship_context": {
                "commit": "97836b7825606e28d73cd124115b163278273a35",
                "commit_summary": "Initial commit"
              }
            },
            {
              "type": "statement",
              "id": "st-0038",
              "text": "        sheet[0][\"human_label\"] = (\n            \"DIFFERENT\" if key[sheet[0][\"pair_id\"]] == \"INTERCHANGEABLE\" else \"INTERCHANGEABLE\"\n        )\n",
              "kind": "assign",
              "span": {
                "start_line": 103,
                "end_line": 105
              },
              "authored_by": "Adam Conway",
              "authored_at": "2026-07-02T02:43:03Z",
              "author_type": "human",
              "authorship_context": {
                "commit": "97836b7825606e28d73cd124115b163278273a35",
                "commit_summary": "Initial commit"
              }
            },
            {
              "type": "statement",
              "id": "st-0039",
              "text": "        sheet[1][\"human_label\"] = \"\"\n",
              "kind": "assign",
              "span": {
                "start_line": 106,
                "end_line": 106
              },
              "authored_by": "Adam Conway",
              "authored_at": "2026-07-02T02:43:03Z",
              "author_type": "human",
              "authorship_context": {
                "commit": "97836b7825606e28d73cd124115b163278273a35",
                "commit_summary": "Initial commit"
              }
            },
            {
              "type": "statement",
              "id": "st-0040",
              "text": "        sheet_path.write_text(json.dumps(sheet))\n",
              "kind": "expr",
              "span": {
                "start_line": 107,
                "end_line": 107
              },
              "authored_by": "Adam Conway",
              "authored_at": "2026-07-02T02:43:03Z",
              "author_type": "human",
              "authorship_context": {
                "commit": "97836b7825606e28d73cd124115b163278273a35",
                "commit_summary": "Initial commit"
              }
            },
            {
              "type": "statement",
              "id": "st-0041",
              "text": "\n        result = compute_kappa_from_files(sheet_path, key_path)\n",
              "kind": "assign",
              "span": {
                "start_line": 108,
                "end_line": 109
              },
              "authored_by": "Adam Conway",
              "authored_at": "2026-07-02T02:43:03Z",
              "author_type": "human",
              "authorship_context": {
                "commit": "97836b7825606e28d73cd124115b163278273a35",
                "commit_summary": "Initial commit"
              }
            },
            {
              "type": "statement",
              "id": "st-0042",
              "text": "        assert result[\"n_skipped\"] == 1\n",
              "kind": "assert",
              "span": {
                "start_line": 110,
                "end_line": 110
              },
              "authored_by": "Adam Conway",
              "authored_at": "2026-07-02T02:43:03Z",
              "author_type": "human",
              "authorship_context": {
                "commit": "97836b7825606e28d73cd124115b163278273a35",
                "commit_summary": "Initial commit"
              }
            },
            {
              "type": "statement",
              "id": "st-0043",
              "text": "        assert result[\"n_labeled\"] == len(sheet) - 1\n",
              "kind": "assert",
              "span": {
                "start_line": 111,
                "end_line": 111
              },
              "authored_by": "Adam Conway",
              "authored_at": "2026-07-02T02:43:03Z",
              "author_type": "human",
              "authorship_context": {
                "commit": "97836b7825606e28d73cd124115b163278273a35",
                "commit_summary": "Initial commit"
              }
            },
            {
              "type": "statement",
              "id": "st-0044",
              "text": "        assert 0 < result[\"kappa\"] < 1\n",
              "kind": "assert",
              "span": {
                "start_line": 112,
                "end_line": 112
              },
              "authored_by": "Adam Conway",
              "authored_at": "2026-07-02T02:43:03Z",
              "author_type": "human",
              "authorship_context": {
                "commit": "97836b7825606e28d73cd124115b163278273a35",
                "commit_summary": "Initial commit"
              }
            }
          ],
          "authored_by": "Adam Conway",
          "authored_at": "2026-07-02T02:43:03Z",
          "author_type": "human",
          "authorship_context": {
            "commit": "97836b7825606e28d73cd124115b163278273a35",
            "commit_summary": "Initial commit"
          }
        }
